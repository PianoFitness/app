          "sql": "CREATE TABLE IF NOT EXISTS \"exercise_history_table\" (\"id\" TEXT NOT NULL, \"profile_id\" TEXT NOT NULL REFERENCES user_profile_table(id) ON DELETE CASCADE, \"completed_at\" INTEGER NOT NULL, \"practice_mode\" TEXT NOT NULL, \"hand_selection\" TEXT NOT NULL, \"musical_key\" TEXT NULL, \"scale_type\" TEXT NULL, \"chord_type\" TEXT NULL, \"include_inversions\" INTEGER NOT NULL DEFAULT 0 CHECK (\"include_inversions\" IN (0, 1)), \"include_seventh_chords\" INTEGER NOT NULL DEFAULT 0 CHECK (\"include_seventh_chords\" IN (0, 1)), \"musical_note\" TEXT NULL, \"arpeggio_type\" TEXT NULL, \"arpeggio_octaves\" TEXT NULL, \"chord_progression_id\" TEXT NULL, PRIMARY KEY (\"id\"));"
